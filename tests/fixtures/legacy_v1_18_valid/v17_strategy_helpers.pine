strategy("v17 strategy helpers", overlay=true, commission_type=strategy.commission.percent, commission_value=0.1)
strategy.risk.max_drawdown(10, strategy.percent_of_equity)
hk = ticker.heikinashi(syminfo.tickerid)
st = request.security(hk, timeframe.period, ta.supertrend(3.0, 10))
a = array.from(1.0, 2.0, 3.0)
