//@version=6
strategy("Optimizer Contract", overlay = true)
import user/Lib/1 as lib
qty = input.float(1.0, "Qty", minval = 0.1, step = 0.1)
fast = input.int(12, "Fast", options = [8, 12, 21])
ma = ta.sma(close, fast)
remote = request.security(syminfo.tickerid, "D", ma)
alertcondition(ma > close, "Cross", "cross")
line.new(bar_index, close, bar_index + 1, ma)
ext = lib.score(remote)
strategy.entry("L", strategy.long, qty = qty)
plot(ma)
