type Bar
    o = float
    h = float
    l = float
    c = float

makeBar(o, h, l, c) =>
    Bar.new(o, h, l, c)

b = makeBar(open, high, low, close)
bb = b.c * 2
r = request.security(syminfo.tickerid, "D", close, lookahead=barmerge.lookahead_on, gaps=barmerge.gaps_off)
a = array.new<float>(20, 0.0)
for i = 0 to 19
    array.set(a, i, close[i] - open[i])
m = matrix.new<float>(3, 3, 0.0)
matrix.set(m, 0, 0, close)
matrix.add_row(m, 0, array.from(1.0, 2.0, 3.0))
det = matrix.det(m)
if ta.crossunder(close, ta.sma(close, 20))
    alert("crossunder", alert.freq_once_per_bar_close)
x = switch
    close > open => 1
    close < open => 2
    => 0
plot(x, title="switch_x")
plot(det, title="det")
plot(bb, title="bb")